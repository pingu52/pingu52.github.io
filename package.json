{
  "name": "pingu's Blog",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "test": "node --test --loader ./tests/ts-loader.mjs tests/**/*.test.ts",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit",
    "new-post": "node scripts/blog-cli.mjs post",
    "format": "biome format --write ./src",
    "lint": "biome check --write ./src",
    "lint:ci": "biome check ./src",
    "preinstall": "npx only-allow pnpm",
    "blog": "node scripts/blog-cli.mjs",
    "blog:tax": "node scripts/blog-cli.mjs tax",
    "blog:post": "node scripts/blog-cli.mjs post"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/svelte": "^7.2.5",
    "@expressive-code/core": "^0.41.7",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-regular": "^1.2.4",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.82",
    "@iconify/svelte": "^5.2.2",
    "@swup/astro": "^1.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^6.4.8",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "hastscript": "^9.0.1",
    "katex": "^0.16.47",
    "markdown-it": "^14.3.0",
    "mdast-util-to-string": "^4.0.0",
    "overlayscrollbars": "^2.16.0",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-directive-rehype": "^1.0.0",
    "remark-github-admonitions-to-directives": "^2.1.0",
    "remark-math": "^6.0.0",
    "remark-sectionize": "^2.1.0",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.5",
    "stylus": "^0.64.0",
    "svelte": "^5.56.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.10",
    "@biomejs/biome": "^2.5.2",
    "@tailwindcss/typography": "0.5.19",
    "@types/hast": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/mdast": "^4.0.4",
    "@types/sanitize-html": "^2.16.1",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0"
  },
  "packageManager": "pnpm@10.34.2",
  "pnpm": {
    "overrides": {
      "rollup-plugin-terser>serialize-javascript": "7.0.5",
      "astro>esbuild": "0.28.1"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
